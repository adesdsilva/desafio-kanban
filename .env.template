# 🔐 Arquivo de Template de Variáveis de Ambiente
# COPIE este arquivo para .env e preencha com seus valores reais
# ⚠️ NÃO commite arquivo .env no Git!

# ========================================
# 🔵 AMBIENTE: DEV (Desenvolvimento Local)
# ========================================

# JWT
DEV_JWT_SECRET=dev-secret-key-only-for-development-32chars
DEV_JWT_EXPIRATION=86400000

# Database
DEV_DB_HOST=localhost
DEV_DB_PORT=5432
DEV_DB_NAME=kanban_dev
DEV_DB_USER=postgres
DEV_DB_PASSWORD=admin

# Application
DEV_APP_ENV=dev
DEV_DEBUG=true

# ========================================
# 🟡 AMBIENTE: HOMOL (Homologação)
# ========================================

# JWT
HOMOL_JWT_SECRET=homol-super-secret-key-at-least-32-chars-long-change-this
HOMOL_JWT_EXPIRATION=86400000

# Database
HOMOL_DB_HOST=homol-db.seu-dominio.com
HOMOL_DB_PORT=5432
HOMOL_DB_NAME=kanban_homol
HOMOL_DB_USER=kanban_user
HOMOL_DB_PASSWORD=seu_password_super_seguro_aqui_123

# Application
HOMOL_APP_ENV=homol
HOMOL_DEBUG=false

# URLs
HOMOL_API_URL=https://api-homol.kanban-saas.com
HOMOL_CORS_ORIGINS=https://homol.kanban-saas.com,https://api-homol.kanban-saas.com

# ========================================
# 🔴 AMBIENTE: PROD (Produção)
# ========================================

# JWT - ⚠️ GERAR COM CHAVE ALEATÓRIA MUITO SEGURA
PROD_JWT_SECRET=prod-super-secret-key-MUST-BE-VERY-SECURE-32-chars-CHANGE-THIS-IMMEDIATELY
PROD_JWT_EXPIRATION=86400000

# Database - ⚠️ USE CREDENCIAIS MUITO SEGURAS
PROD_DB_HOST=prod-db.seu-dominio.com
PROD_DB_PORT=5432
PROD_DB_NAME=kanban_prod
PROD_DB_USER=kanban_prod_user
PROD_DB_PASSWORD=very_secure_password_with_special_chars_!@#$%^&*()

# Application
PROD_APP_ENV=prod
PROD_DEBUG=false

# URLs
PROD_API_URL=https://api.kanban-saas.com
PROD_CORS_ORIGINS=https://kanban-saas.com,https://api.kanban-saas.com

# JVM Options
PROD_JAVA_OPTS=-Xmx2g -Xms1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ========================================
# 🐳 AMBIENTE: DOCKER (Container)
# ========================================

# JWT
DOCKER_JWT_SECRET=docker-dev-secret-key-32chars-long-for-development
DOCKER_JWT_EXPIRATION=86400000

# Database
DOCKER_DB_HOST=db
DOCKER_DB_PORT=5432
DOCKER_DB_NAME=kanban_docker
DOCKER_DB_USER=postgres
DOCKER_DB_PASSWORD=admin

# Application
DOCKER_APP_ENV=docker
DOCKER_DEBUG=true

# ========================================
# ⚠️ INSTRUÇÕES IMPORTANTES
# ========================================

# 1. CRIAR ARQUIVO .env NA RAIZ DO PROJETO
#    cp .env.template .env

# 2. PREENCHER COM VALORES REAIS:
#    - Todos os JWT_SECRET devem ter >= 32 caracteres
#    - Use senhas fortes em HOMOL/PROD
#    - NÃO use mesmos secrets em DEV/HOMOL/PROD

# 3. ADICIONAR .env AO .gitignore
#    echo ".env" >> .gitignore

# 4. GERAR SECRETS ALEATÓRIOS SEGUROS:
#    openssl rand -base64 32

# 5. NÃO COMPARTILHAR arquivo .env
#    Cada pessoa tem seu próprio .env local

# 6. EM PRODUÇÃO:
#    - Usar variables de ambiente do SO
#    - Ou usar secrets management (AWS Secrets Manager, HashiCorp Vault, etc)
#    - NUNCA commitar secrets no Git

# ========================================
# 🔧 COMO USAR
# ========================================

# LOCAL (DEV):
# export $(cat .env | grep "^DEV_" | xargs)
# ./mvnw spring-boot:run -Dspring.profiles.active=dev

# HOMOL:
# export $(cat .env | grep "^HOMOL_" | xargs)
# ./mvnw spring-boot:run -Dspring.profiles.active=homol

# PROD:
# export $(cat .env | grep "^PROD_" | xargs)
# java -jar kanban-project.jar --spring.profiles.active=prod

# DOCKER:
# docker-compose up (usa .env automaticamente)

# ========================================
# 📋 CHECKLIST DE SEGURANÇA
# ========================================

# [ ] JWT_SECRET tem >= 32 caracteres em todos ambientes
# [ ] DB_PASSWORD é forte em HOMOL/PROD (>=12 chars, mix, special)
# [ ] .env está em .gitignore
# [ ] .env NÃO foi commitado
# [ ] Diferentes secrets para cada ambiente
# [ ] Backup de secrets feito em lugar seguro
# [ ] Acesso a .env restrito (chmod 600)
# [ ] Rotação de secrets planejada (a cada 3-6 meses)

# ========================================
# 🔒 GERADORES DE SECRETS SEGUROS
# ========================================

# Linux/Mac:
# openssl rand -base64 32

# Python:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# Java:
# java -c "java.util.UUID.randomUUID()"

# Online (apenas para DEV - NUNCA para PROD):
# https://randomkeygen.com/

